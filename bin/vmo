#!/bin/sh

infile=""
ext=""

rotations="none"
zoom=0.4
iso=0.03

render="false"
lowres="false"
trans="false"
dens="false"
mos="true"

main()
{
  argparse $@

  run_vmd
}

run_vmd()
{
  [ ${render} = "true" ] && display="none" || display="window"

  vmd -dispdev ${display} -e ${CHEM_ROOT}/templates/vmo.tcl -args \
    ${infile} ${ext} \
    ${rotations} ${zoom} ${iso} \
    ${render} ${lowres} ${trans} ${dens} ${mos}
}

argparse()
{
  while :; do
    case $1 in
      -h|--help)
        help && exit ;;
      --render)
        render="true" ;;
      -z|--zoom)
        zoom=$2
        shift ;;
      -l|--lowres)
        lowres="true" ;;
      -r|--rotate)
        rotations=$2
        shift ;;
      -d|--dens)
        dens="true"
        mos="false" ;;
      -i|--iso)
        iso=$2
        shift ;;
      -t|--trans)
        trans="true" ;;
      -c|--clean)
        clean="true" ;;
      --)
        shift
        break ;;
      -?*)
        printf 'Ignoring unknown option: %s\n' "$1" >&2 ;;
      *)
        break ;;
    esac
    shift
  done

  [ -z $1 ] && echo "Input file required." && exit 1
  [ ! -f $1 ] && printf 'File not found: %s\n' "$1" >&2 && exit 1

  infile="$(pwd)/$1"
  ext=${infile##*.}
  [ ${ext} = "cub" ] && ext="cube" || [ ${ext} = "xyz" ] && mos="false"
}

help() {
  local script_name=$(basename $0)
  echo "Usage: ${script_name} [OPTION]... FILE"
  echo "Visualize molecules and orbitals.\n"
  echo "  -h, --help                    Display this message again. :)"
  echo "  -v, --verbose                 Debug mode."
  echo "      --render                  Render image at 4000x4000 px."
  echo "  -l, --lowres                  Use 1000x1000 px resolution instead."
  echo "  -r, --rotate  <AXIS><VALUE>   Rotate around an axis. (comma-separated list)"
  echo "  -z, --zoom    ZOOM            Set zoom factor. (default: 0.4)"
  echo "  -i, --iso     CONTOUR         Isosurface value. (default: 0.03)"
  echo "  -t, --trans                   Make isosurface transparent."
  echo "  -d, --dens                    Plot the spin density."
  echo
  echo "Example:"
  echo "  ${script_name} -r x45,y10 -z 0.9 coord.xyz"
}


main $@
